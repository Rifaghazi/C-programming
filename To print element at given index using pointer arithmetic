#include <stdio.h>

int main()
{
    int arr[10], n, index, i;
    int *ptr;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements:\n");
    for(i=0;i<n;i++)
    {
        scanf("%d",&arr[i]);
    }

    printf("Enter index: ");
    scanf("%d",&index);

    ptr = arr;

    printf("Element at index %d is: %d", index, *(ptr + index));

    return 0;
}
